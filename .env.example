# Cách 2 - Tunnel (khuyến nghị cho điện thoại thật iOS/Android)
# Copy file này thành .env. Hướng dẫn chi tiết: MO/docs/TUNNEL_SETUP.md
#
# Bước 1: Chạy BE (cd BE && npm run start)
# Bước 2: Chạy tunnel: ngrok http 5000  HOẶC  cloudflared tunnel --url http://localhost:5000
# Bước 3: Dán URL https vào dưới (không có dấu / cuối). Ví dụ:
#   ngrok:     https://abc123.ngrok-free.app
#   Cloudflare: https://xxx.trycloudflare.com
# Bước 4: npx expo start -c  và mở app trên điện thoại bằng Expo Go
#
EXPO_PUBLIC_API_URL=https://your-tunnel-url.ngrok-free.app
#
# (Tùy chọn) Emulator/simulator dùng localhost: EXPO_PUBLIC_API_URL=http://localhost:5000
# (Tùy chọn) Máy thật dùng IP WiFi: EXPO_PUBLIC_API_URL=http://192.168.1.5:5000
